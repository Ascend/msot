<?xml version="1.0" encoding="UTF-8"?>
<config name="mindstudio-operator-tools" dst_path="mindstudio-operator-tools" install_path="mindstudio-operator-tools" install_own="$username:$usergroup" install_mod="550">
    <!-- install directory -->
    <dir_info value="common" install_mod="550">
        <path value="${TARGET_ENV}"/>
        <path value="${TARGET_ENV}/bin" install_softlink="bin"/>
        <path value="tools" install_mod="750"/>
        <path value="python" install_mod="750"/>
        <path value="python/site-packages" install_mod="750"/>
    </dir_info>

    <dir_info value="mindstudio-operator-tools">
        <path value="share/info/mindstudio-operator-tools/script"/>
    </dir_info>

    <file_info value="install_info" copy_type="delivery" src_path="" dst_path="share/info/mindstudio-operator-tools" install_path="share/info/mindstudio-operator-tools" install_mod="440">
        <file value="version.info"/>
        <file value="scene.info"/>
    </file_info>

    <file_info value="scripts" copy_type="source" src_path="package/script" dst_path="share/info/mindstudio-operator-tools/script" install_path="share/info/mindstudio-operator-tools/script" install_mod="550">
        <file value="install.sh"/>
        <file value="uninstall.sh"/>
        <file value="cann_uninstall.sh"/>
        <file value="common.sh"/>
        <file value="filelist.csv" copy_type="delivery" src_path="" install_mod="440"/>
        <file value="parser_install.sh" copy_type="delivery" src_path=""/>
        <file value="help.info" src_path="package/conf" install_mod="440"/>
    </file_info>

    <file_info value="package" copy_type="source" src_path="${OUTPUT}" dst_path="mindstudio-operator-tools" install_path="mindstudio-operator-tools" install_mod="550">
        <!-- tool 属性用于排除工具参数过滤；未设置 tool 的公共文件始终打入总包。 -->
        <!-- msopgen 同时产出 mindstudio_opgen 与 mindstudio_opst，因此两个 whl 使用同一个 tool 标记。 -->
        <file value="mskpp/mindstudio_kpp-*.whl" tool="mskpp" />
        <file value="mskl/mindstudio_kl-*.whl" tool="mskl" />
        <file value="msopgen/mindstudio_opgen-*.whl" tool="msopgen" />
        <file value="msopgen/mindstudio_opst-*.whl" tool="msopgen" />
        <file value="msdebug/mindstudio-debugger_*.run" tool="msdebug" />
        <file value="mssanitizer/mindstudio-sanitizer_*.run" tool="mssanitizer" />
        <file value="msopprof/mindstudio-opprof_*.run" tool="msopprof" />
    </file_info>

</config>
